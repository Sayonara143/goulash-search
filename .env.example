# --- GigaChat ---
# Авторизационный ключ из личного кабинета developers.sber.ru (GigaChat API).
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_BASE_URL=https://api.giga.chat/v1
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# В REST API используется GigaChat-2, а не маркетинговое имя GigaChat-2-Lite.
# Другие модели, если доступны вашему аккаунту: GigaChat-2, GigaChat-Pro,
# GigaChat-Max, GigaChat-2-Pro, GigaChat-2-Max.
# Безопасный режим: true. Если TLS не проходит, установите Russian Trusted Root CA
# или задайте GIGACHAT_CA_BUNDLE_FILE для REST-клиента GigaChat.
GIGACHAT_VERIFY_SSL_CERTS=true
GIGACHAT_CA_BUNDLE_FILE=

# --- Поиск (опционально) ---
# Приоритет: Яндекс -> Tavily -> бесплатный DuckDuckGo (если ничего не задано).
# Для тестов: true отключает поисковые API и берёт URL из supplier_finder/fixed_search_urls.py.
USE_FIXED_SEARCH_URLS=false
# Yandex Search API v2: нужны ключ и идентификатор каталога (folderId) из Yandex Cloud.
YANDEX_SEARCH_API_KEY=
YANDEX_FOLDER_ID=
TAVILY_API_KEY=

# --- Доступ к веб-интерфейсу (опционально) ---
# Пароль для входа в Streamlit-приложение. Пусто = вход без пароля.
APP_PASSWORD=

# --- Скрапинг ---
REQUEST_TIMEOUT=15
MAX_CONCURRENCY=5
